{
  "name": "syngrafo-frontend",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "packages/react-client",
    "packages/editor",
    "packages/shared",
    "packages/ui",
    "packages/audio",
    "packages/video"
  ],
  "scripts": {
    "build": "cd packages/react-client && bun run build.ts --minify",
    "dev": "cd packages/react-client && bun run dev",
    "install-all": "bun install",
    "i18n:extract": "cd packages/react-client && bun run i18n:extract",
    "i18n:compile": "cd packages/react-client && bun run i18n:compile",
    "i18n": "bun run i18n:extract && bun run i18n:compile"
  }
}
