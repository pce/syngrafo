{
  "name": "bun-react-template",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "start": "NODE_ENV=production bun src/index.ts",
    "build": "bun run build.ts",
    "test": "bun test src",
    "i18n:extract": "CI=1 bun ./node_modules/@lingui/cli/dist/lingui.js extract",
    "i18n:compile": "CI=1 bun ./node_modules/@lingui/cli/dist/lingui.js compile --typescript",
    "i18n": "bun run i18n:extract && bun run i18n:compile"
  },
  "dependencies": {
    "@syngrafo/audio": "workspace:*",
    "@syngrafo/editor": "workspace:*",
    "@syngrafo/shared": "workspace:*",
    "@syngrafo/ui": "workspace:*",
    "@syngrafo/video": "workspace:*",
    "@lingui/core": "^6.0.1",
    "@lingui/format-po": "^6.0.1",
    "@lingui/react": "^6.0.1",
    "@mkkellogg/gaussian-splats-3d": "^0.4.7",
    "@types/three": "^0.184.1",
    "bun-plugin-tailwind": "^0.1.2",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "tailwindcss": "^4.3.0",
    "three": "^0.184.0",
    "three-mesh-bvh": "^0.9.9"
  },
  "devDependencies": {
    "@lingui/cli": "^6.0.1",
    "@lingui/conf": "^6.0.1",
    "@saucer-dev/types": "^2.0.1",
    "@types/bun": "^1.3.13",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3"
  }
}
